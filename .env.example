# ============================================================
# .env.example — Copy this to '.env' and fill in your values
# NEVER commit your real .env file to GitHub!
# ============================================================

# --- ThingSpeak ---
# Get this from your ThingSpeak channel → API Keys tab
THINGSPEAK_WRITE_API_KEY=YOUR_THINGSPEAK_WRITE_API_KEY_HERE

# --- Email (Gmail with App Password) ---
# How to get App Password: myaccount.google.com → Security → App Passwords
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECEIVER=alert_destination@email.com

# --- Fast2SMS (for SMS alerts) ---
# Get API key from: https://www.fast2sms.com/dashboard/dev-api
FAST2SMS_API_KEY=your_fast2sms_api_key_here
ALERT_PHONE_NUMBER=9876543210

# --- Threshold ---
# Net acceleration in m/s² that triggers an alert
# Suggested starting value: 10.0
ACCELERATION_THRESHOLD=10.0
